# MFI-ESTIMATION
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Estimation Gratuite – MFI Immobilier</title>
  <meta name="description" content="Obtenez une estimation gratuite et sans engagement de votre bien immobilier avec Sacha Théry, expert local MFI – Malzéville & Essey-lès-Nancy." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:     #1B3A6B;
      --navy-dk:  #0F2347;
      --gold:     #C9A96E;
      --gold-lt:  #E2C898;
      --white:    #FFFFFF;
      --gray:     #b8c4d8;
      --border:   rgba(201,169,110,0.30);
      --r:        5px;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #1B3A6B;
      color: var(--white);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── HEADER ── */
    header {
      position: relative; z-index: 10;
      display: flex; align-items: center; justify-content: space-between;
      padding: 22px 48px;
      background: #0F2347;
      border-bottom: 2px solid var(--border);
    }

    .logo { display: flex; align-items: center; gap: 16px; }

    .logo-img {
      height: 56px; width: auto;
      /* logo a fond blanc — on le met sur fond sombre avec un léger filtre */
      background: #fff;
      border-radius: 6px;
      padding: 6px 10px;
    }

    .logo-sep { width: 1px; height: 38px; background: var(--border); }

    .logo-text .name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem; font-weight: 600; letter-spacing: 0.06em;
      color: var(--white);
    }

    .logo-text .tag {
      font-size: 0.6rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--gold); font-weight: 300;
    }

    .hdr-right { font-size: 0.78rem; color: var(--gray); }
    .hdr-right a { color: var(--gold-lt); text-decoration: none; font-weight: 500; }

    /* ── HERO ── */
    .hero-wrapper {
      background: #0F2347;
      border-bottom: 1px solid var(--border);
    }

    .hero {
      position: relative; z-index: 10;
      display: flex; align-items: center; justify-content: center;
      gap: 72px;
      padding: 72px 64px 80px;
      max-width: 1100px; margin: 0 auto;
    }

    .hero-text { flex: 1; }

    .pill {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(201,169,110,0.15);
      border: 1px solid var(--border);
      border-radius: 100px; padding: 6px 18px;
      font-size: 0.68rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--gold);
      margin-bottom: 28px;
    }
    .dot { width: 5px; height: 5px; border-radius: 50%; background: var(--gold); }

    .hero-text h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.6rem, 4vw, 4rem);
      font-weight: 300; line-height: 1.18; margin-bottom: 20px;
      color: #C9A96E;
      text-shadow: 0 2px 24px rgba(0,0,0,0.4);
    }
    .hero-text h1 em { font-style: italic; color: var(--gold-lt); }

    .hero-text p {
      font-size: 1rem; color: #ffffff;
      line-height: 1.75; margin-bottom: 0; font-weight: 300;
    }

    /* portrait */
    .hero-portrait { flex-shrink: 0; position: relative; }

    .portrait-frame {
      width: 240px; height: 295px;
      border-radius: 12px;
      overflow: hidden;
      border: 2px solid var(--border);
      box-shadow: 0 24px 64px rgba(0,0,0,0.5);
    }

    .portrait-frame img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center top; display: block;
    }

    .portrait-badge {
      position: absolute;
      bottom: -20px; left: 50%; transform: translateX(-50%);
      background: #0F2347;
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 9px 22px;
      white-space: nowrap; text-align: center;
      box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .portrait-badge .pname { font-size: 0.83rem; font-weight: 500; color: #fff; }
    .portrait-badge .prole { font-size: 0.64rem; color: var(--gold); letter-spacing: 0.08em; }

    /* ── DIVIDER LINE ── */
    .divider-line {
      border: none;
      border-top: 1px solid var(--border);
      max-width: 1100px;
      margin: 0 auto;
    }

    /* ── FORM SECTION ── */
    .form-section {
      position: relative; z-index: 10;
      max-width: 680px; margin: 56px auto 80px; padding: 0 24px;
    }

    .card {
      background: #0F2347;
      border: 1px solid var(--border);
      border-radius: 14px; padding: 44px 44px 40px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }

    .card h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem; font-weight: 400; margin-bottom: 6px;
      color: #fff;
    }
    .card-sub { font-size: 0.78rem; color: var(--gray); font-weight: 300; margin-bottom: 28px; }

    .fg { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }

    label {
      font-size: 0.67rem; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--gold);
    }

    input, select, textarea {
      background: #1B3A6B;
      border: 1px solid rgba(201,169,110,0.3);
      border-radius: var(--r);
      color: #FFFFFF;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.92rem; padding: 13px 15px;
      outline: none; transition: border-color .2s, background .2s;
      width: 100%; -webkit-appearance: none;
    }

    input::placeholder, textarea::placeholder {
      color: rgba(255,255,255,0.35);
    }

    select { cursor: pointer; }
    select option { background: #1B3A6B; color: #fff; }

    input:focus, select:focus, textarea:focus {
      border-color: var(--gold);
      background: #1e3f78;
      color: #fff;
    }

    textarea { resize: vertical; min-height: 90px; }

    .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

    .sep {
      display: flex; align-items: center; gap: 10px;
      margin: 24px 0 16px;
    }
    .sep::before, .sep::after { content: ''; flex: 1; height: 1px; background: var(--border); }
    .sep span { font-size: 0.63rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gray); }

    /* BUTTON */
    .btn {
      display: flex; align-items: center; justify-content: center;
      gap: 10px; width: 100%; padding: 16px 24px; margin-top: 10px;
      background: linear-gradient(135deg, var(--gold) 0%, #b8913a 100%);
      border: none; border-radius: var(--r);
      color: #0F2347; font-family: 'DM Sans', sans-serif;
      font-size: 0.93rem; font-weight: 600; letter-spacing: 0.04em;
      cursor: pointer; transition: transform .15s, box-shadow .15s, filter .15s;
    }

    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(201,169,110,0.35);
      filter: brightness(1.06);
    }
    .btn:active { transform: translateY(0); }
    .btn:disabled { opacity: 0.65; cursor: default; transform: none; }

    .btn-note {
      text-align: center; font-size: 0.7rem;
      color: var(--gray); margin-top: 12px; font-weight: 300;
    }

    /* SUCCESS */
    #success-msg { display: none; text-align: center; padding: 28px 0 10px; }

    .check-circle {
      width: 54px; height: 54px; border-radius: 50%;
      background: rgba(201,169,110,0.12);
      border: 1.5px solid var(--gold);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 20px;
    }

    #success-msg h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem; font-weight: 400; margin-bottom: 8px; color: #fff;
    }
    #success-msg p { font-size: 0.85rem; color: var(--gray); font-weight: 300; line-height: 1.65; }

    /* BADGES */
    .badges {
      position: relative; z-index: 10;
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 14px; max-width: 680px;
      margin: 0 auto 80px; padding: 0 24px;
    }

    .badge {
      background: #0F2347;
      border: 1px solid var(--border);
      border-radius: 10px; padding: 22px 14px; text-align: center;
      box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .badge-icon { font-size: 1.4rem; margin-bottom: 9px; }
    .badge-label { font-size: 0.8rem; font-weight: 500; margin-bottom: 4px; color: #fff; }
    .badge-desc { font-size: 0.68rem; color: var(--gray); font-weight: 300; line-height: 1.5; }

    /* FOOTER */
    footer {
      position: relative; z-index: 10;
      text-align: center; padding: 26px 24px 38px;
      background: #0F2347;
      border-top: 1px solid var(--border);
      font-size: 0.72rem; color: var(--gray); font-weight: 300;
    }
    footer strong { color: var(--gold); font-weight: 400; }
    footer a { color: var(--gold); text-decoration: none; }

    @media (max-width: 820px) {
      .hero { flex-direction: column; gap: 52px; padding: 52px 24px 60px; text-align: center; }
      .hero-portrait { order: -1; }
      .portrait-frame { width: 200px; height: 248px; }
    }

    @media (max-width: 600px) {
      header { padding: 18px 20px; }
      .hdr-right { display: none; }
      .card { padding: 28px 20px 26px; }
      .row2 { grid-template-columns: 1fr; }
      .badges { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<header>
  <div class="logo">
    <img class="logo-img" src="data:image/png;base64," alt="MFI Immobilier" />
    <div class="logo-sep"></div>
    <div class="logo-text">
      <div class="name">Mathieu Floirac Immobilier</div>
      <div class="tag">Malzéville · Essey-lès-Nancy</div>
    </div>
  </div>
  <div class="hdr-right">
    <a href="tel:0383205000">03 83 20 50 00</a>&nbsp;·&nbsp;<a href="https://mfi-immo.fr" target="_blank">mfi-immo.fr</a>
  </div>
</header>

<div class="hero-wrapper"><section class="hero">
  <div class="hero-text">
    <div class="pill"><span class="dot"></span>100% Gratuit &amp; Sans Engagement</div>
    <h1>Combien vaut<br>votre bien <em>aujourd'hui&nbsp;?</em></h1>
    <p>Le marché a évolué dans votre secteur. Avant de vendre, obtenez une estimation précise réalisée par votre expert local MFI.</p>
  </div>
  <div class="hero-portrait">
    <div class="portrait-frame">
      <img src="data:image/png;base64," alt="Sacha Théry – Agent MFI" />
    </div>
    <div class="portrait-badge">
      <div class="pname">Sacha Théry</div>
      <div class="prole">Agent immobilier · MFI</div>
    </div>
  </div>
</section></div>

<hr class="divider-line" />

<div class="form-section">
  <div class="card">
    <h2>Votre demande d'estimation</h2>
    <p class="card-sub">Remplissez ce formulaire — je vous recontacte sous 24h.</p>


    <form id="estim-form" action="https://formspree.io/f/mnjrqorp" method="POST">
      <input type="hidden" name="_subject" value="🏠 Nouvelle demande d'estimation – MFI" />

      <div class="sep"><span>Vos coordonnées</span></div>

      <div class="row2">
        <div class="fg">
          <label for="prenom">Prénom</label>
          <input type="text" id="prenom" name="Prénom" placeholder="Jean" required />
        </div>
        <div class="fg">
          <label for="nom">Nom</label>
          <input type="text" id="nom" name="Nom" placeholder="Dupont" required />
        </div>
      </div>

      <div class="row2">
        <div class="fg">
          <label for="tel">Téléphone</label>
          <input type="tel" id="tel" name="Téléphone" placeholder="06 xx xx xx xx" required />
        </div>
        <div class="fg">
          <label for="email">Email</label>
          <input type="email" id="email" name="Email" placeholder="jean@exemple.fr" />
        </div>
      </div>

      <div class="sep"><span>Votre bien</span></div>

      <div class="row2">
        <div class="fg">
          <label for="type">Type de bien</label>
          <select id="type" name="Type de bien" required>
            <option value="" disabled selected>Choisir…</option>
            <option>Appartement</option>
            <option>Maison</option>
            <option>Terrain</option>
            <option>Autre</option>
          </select>
        </div>
        <div class="fg">
          <label for="surface">Surface (m²)</label>
          <input type="number" id="surface" name="Surface (m²)" placeholder="ex. 85" min="1" />
        </div>
      </div>

      <div class="fg">
        <label for="adresse">Adresse du bien</label>
        <input type="text" id="adresse" name="Adresse du bien" placeholder="Rue, ville, code postal" required />
      </div>

      <div class="row2">
        <div class="fg">
          <label for="pieces">Nombre de pièces</label>
          <input type="text" id="pieces" name="Nombre de pièces" placeholder="ex. 4, studio, duplex…" />
        </div>
        <div class="fg">
          <label for="dispo">Horizon du projet</label>
          <select id="dispo" name="Horizon du projet">
            <option value="" disabled selected>Choisir…</option>
            <option>Dans le mois</option>
            <option>Dans les 3 mois</option>
            <option>Dans les 6 mois</option>
            <option>Je me renseigne</option>
          </select>
        </div>
      </div>

      <div class="fg">
        <label for="message">Informations complémentaires</label>
        <textarea id="message" name="Message" placeholder="Étage, parking, état général, travaux récents…"></textarea>
      </div>

      <button type="submit" class="btn" id="submit-btn">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
        Envoyer ma demande d'estimation
      </button>
      <p class="btn-note">Réponse garantie sous 24h · Vos données restent confidentielles</p>
    </form>

    <div id="success-msg">
      <div class="check-circle">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C9A96E" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <h3>Demande envoyée !</h3>
      <p>Merci. Sacha Théry vous recontacte sous 24h<br>pour organiser votre estimation gratuite.</p>
    </div>
  </div>
</div>

<div class="badges">
  <div class="badge">
    <div class="badge-icon">🎯</div>
    <div class="badge-label">Estimation précise</div>
    <div class="badge-desc">Basée sur les ventes réelles du secteur</div>
  </div>
  <div class="badge">
    <div class="badge-icon">🔒</div>
    <div class="badge-label">Sans engagement</div>
    <div class="badge-desc">100% gratuit, aucune obligation</div>
  </div>
  <div class="badge">
    <div class="badge-icon">⚡</div>
    <div class="badge-label">Réponse rapide</div>
    <div class="badge-desc">Contact sous 24h garanti</div>
  </div>
</div>

<footer>
  <strong>MFI – Mathieu Floirac Immobilier</strong><br>
  Malzéville · Essey-lès-Nancy &nbsp;·&nbsp;
  <a href="tel:0383205000">03 83 20 50 00</a> &nbsp;·&nbsp;
  <a href="https://mfi-immo.fr" target="_blank">mfi-immo.fr</a>
</footer>

<script>
  const form = document.getElementById('estim-form');
  const successMsg = document.getElementById('success-msg');
  const submitBtn = document.getElementById('submit-btn');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.innerHTML = 'Envoi en cours…';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' }
      });

      if (res.ok) {
        form.style.display = 'none';
        successMsg.style.display = 'block';
      } else {
        submitBtn.disabled = false;
        submitBtn.innerHTML = '⚠️ Erreur — Réessayez';
      }
    } catch {
      submitBtn.disabled = false;
      submitBtn.innerHTML = '⚠️ Erreur — Réessayez';
    }
  });
</script>

</body>
</html>
